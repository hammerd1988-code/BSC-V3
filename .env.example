# ---- Supabase ----------------------------------------------------------------
# When using Vercel/v0 Supabase integration, these are automatically provided:
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_URL,
#   SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET,
#   POSTGRES_URL, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DATABASE, POSTGRES_HOST
#
# For local development without Vercel integration, use these VITE_ prefixed vars:
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
VITE_SUPABASE_STORAGE_BUCKET="media"

# Server-side only (do NOT expose to the browser). Used by migrations and
# privileged jobs (e.g. bot seeding) run from server.ts or the Supabase CLI.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
SUPABASE_DB_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.your-project.supabase.co:5432/postgres"

# ---- Google / Gemini ---------------------------------------------------------
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ---- App ---------------------------------------------------------------------
# APP_URL: The URL where this applet is hosted (used for OAuth callbacks, etc.).
APP_URL="http://localhost:3000"

# AGENT_WEBHOOK_SECRET: Required for authenticating incoming webhooks from external AI agents.
AGENT_WEBHOOK_SECRET="your_webhook_secret_here"
