# ---- Supabase ----------------------------------------------------------------
# When using Vercel/v0 Supabase integration, these are automatically provided:
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_URL,
#   SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET,
#   POSTGRES_URL, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DATABASE, POSTGRES_HOST
#
# For local development without Vercel integration, use these VITE_ prefixed vars:
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
VITE_SUPABASE_STORAGE_BUCKET="media"

# Server-side only (do NOT expose to the browser). Used by migrations and
# privileged jobs (e.g. bot seeding) run from server.ts or the Supabase CLI.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
SUPABASE_DB_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.your-project.supabase.co:5432/postgres"

# ---- Google / Gemini ---------------------------------------------------------
# Required by supabase/config.toml auth.external.google for CLI validation and
# local Supabase workflows.
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id_here"
GOOGLE_OAUTH_CLIENT_SECRET="your_google_oauth_client_secret_here"

# Server-side Gemini key for backend-only operations.
GEMINI_API_KEY="your_server_side_gemini_key_here"

# Client-side Gemini key for browser AI features (intentionally public in client bundle).
# Use a restricted key and quota controls when enabling this.
VITE_GEMINI_API_KEY="your_client_side_gemini_key_here"

# ---- AI Endpoint Configuration (Optional) -----------------------------------
# Configure which AI provider powers the app's AI features.
# The app supports any OpenAI-compatible API endpoint.
#
# Priority: per-user settings (Edit Profile → AI Settings) > env vars > Supabase Edge Function
#
# ---- OpenRouter Shortcut (recommended) ----
# Just set these two env vars and the app auto-detects the OpenRouter base URL.
# Works for BOTH server-side (routines, battles, Casper autonomy) and client-side.
OPENROUTER_API_KEY="sk-or-v1-your_openrouter_key_here"
VITE_OPENROUTER_ADMIN_KEY="sk-or-v1-your_openrouter_key_here"
#
# Option 1: OpenRouter (verbose — equivalent to the shortcut above)
#   VITE_AI_BASE_URL="https://openrouter.ai/api/v1"
#   VITE_AI_API_KEY="sk-or-v1-your_openrouter_key_here"
#   VITE_AI_MODEL="google/gemini-2.0-flash-001"   # or "openai/gpt-4o-mini", "anthropic/claude-3.5-haiku", "deepseek/deepseek-chat-v3.1"
#
# Option 2: LM Studio (local development — run models on your own machine, zero cost)
#   VITE_AI_BASE_URL="http://localhost:1234/v1"
#   VITE_AI_API_KEY="lm-studio"          # LM Studio accepts any non-empty key
#   VITE_AI_MODEL="lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF"
#
# Option 3: Direct OpenAI
#   VITE_AI_BASE_URL="https://api.openai.com/v1"
#   VITE_AI_API_KEY="sk-your_openai_key_here"
#   VITE_AI_MODEL="gpt-4o-mini"
#
# If none of these are set, the app falls back to the Supabase Edge Function
# (which uses GEMINI_API_KEY server-side — set that in Railway/Supabase secrets).
#
VITE_AI_BASE_URL="https://openrouter.ai/api/v1"
VITE_AI_API_KEY="sk-or-v1-your_openrouter_key_here"
VITE_AI_MODEL="google/gemini-2.0-flash-001"

# Server-side OpenAI-compatible defaults. Casper can also be configured per user
# from Cognitive Core; keep Casper's judge/operator model separate from bot chatter.
# NOTE: If OPENROUTER_API_KEY is set above, OPENAI_API_KEY is optional — the app
# will use the OpenRouter key automatically for all server-side AI features.
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="your_openai_compatible_server_key_here"
OPENAI_MODEL="gpt-4o-mini"
CASPER_MODEL="gpt-4o-mini"

# Bot/Colosseum automation defaults. Use a cheaper callable model for seeded
# platform bots while Casper can stay on a stronger judge/operator model.
BOT_OPENAI_BASE_URL="https://api.fireworks.ai/inference/v1"
BOT_OPENAI_API_KEY="your_fireworks_or_openai_compatible_bot_key_here"
BOT_DEFAULT_MODEL="accounts/fireworks/models/qwen3p6-plus"

# ---- App ---------------------------------------------------------------------
# APP_URL: The URL where this applet is hosted (used for OAuth callbacks, etc.).
APP_URL="http://localhost:3000"

# Frontend-backend connectivity settings:
# - CLIENT_ORIGIN: allowed web origin for Socket.io CORS (server-side, set on Railway)
# - VITE_SOCKET_URL: Socket.io server URL for frontend (set on Vercel)
#
# Local development:
CLIENT_ORIGIN="http://localhost:3000"
VITE_SOCKET_URL="http://localhost:3001"
#
# Production (split deployment — Vercel frontend + Railway signaling server):
# On Vercel:  VITE_SOCKET_URL="https://your-railway-app.up.railway.app"
# On Railway: CLIENT_ORIGIN="https://bloodsweatcode.net"

# OAuth callback guidance:
# - Add APP_URL and APP_URL/auth/callback in Supabase Auth redirect URL allow-list.
# - For production, set APP_URL to your deployed origin and add the matching callback URL.

# ---- LiveKit Cloud -------------------------------------------------------------
# Create a free LiveKit Cloud project, then set the websocket URL and API keys.
# The Express backend reads LIVEKIT_URL and falls back to VITE_LIVEKIT_URL for
# compatibility with frontend deploy environments. Never expose the API key or
# API secret in VITE_ variables.
LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ---- Runway ML ----------------------------------------------------------------
# Backend-only key used by Casper Studio Visual Forge for AI video and fallback image tasks.
# Do not add a VITE_ prefix; the browser calls /api/runway/* and never sees this key.
RUNWAY_API_KEY="your_runway_api_key_here"
# Optional override for image generation if Runway changes the image model name.
RUNWAY_IMAGE_MODEL="gen4_image"

# ---- Casper Studio Image Provider --------------------------------------------
# Optional: use a self-hosted Z-Image/Z-Image Studio compatible endpoint for image
# generation instead of Runway API credits. Leave unset to use Runway.
# Tongyi-MAI/Z-Image and iconben/z-image-studio are Apache-2.0 projects; expose a
# reachable POST /generate endpoint that returns image_url/imageUrl/url/assetUrl.
# For Railway production, this must be a stable public HTTPS URL, not localhost
# on your laptop unless you expose it through a secure tunnel.
# CASPER_IMAGE_PROVIDER="zimage"
# Z_IMAGE_API_URL="https://your-z-image-host.example.com/generate"
# Z_IMAGE_API_KEY="optional_bearer_token"
# Z_IMAGE_STEPS="8"
# Z_IMAGE_TIMEOUT_MS="300000"

# AGENT_WEBHOOK_SECRET: Required for authenticating incoming webhooks from external AI agents.
AGENT_WEBHOOK_SECRET="your_webhook_secret_here"

# ---- Web Push / PWA -----------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
# Set these on Railway for server-side Push API delivery.
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_SUBJECT="mailto:admin@bloodsweatcode.org"

GROQ_API_KEY=
