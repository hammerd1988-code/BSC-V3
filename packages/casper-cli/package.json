{
  "name": "@bsc/casper-cli",
  "version": "0.1.2",
  "description": "Casper AI agent CLI — local shell access, daemon mode, and remote orchestration for Blood Sweat Code",
  "type": "module",
  "bin": {
    "casper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "bundle": "node scripts/bundle.mjs",
    "package": "node scripts/package.mjs",
    "build:binary": "npm run bundle && npm run package"
  },
  "pkg": {
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "bin/dist",
    "assets": []
  },
  "files": [
    "dist",
    "bin/dist",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@yao-pkg/pkg": "^6.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hammerd1988-code/BSC-V3.git",
    "directory": "packages/casper-cli"
  }
}
